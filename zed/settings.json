// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },
    "session": {
        "trust_all_worktrees": true,
    },
    "preview_tabs": {
        "enabled": false,
        "enable_keep_preview_on_code_navigation": false,
    },
    "relative_line_numbers": "enabled",
    "sticky_scroll": {
        "enabled": false,
    },
    "gutter": {
        "line_numbers": true,
    },
    "minimap": {
        "show": "never",
    },
    "autosave": "on_focus_change",
    "file_types": {
        "html": ["*.html", "*.blade.php", "*.tpl", "*.html", "*.blade.php", "*.tpl"],
        "php": ["*.module", "*.module"],
    },
    "linked_edits": true,
    "show_edit_predictions": true,
    "wrap_guides": [120],
    "preferred_line_length": 120,
    "soft_wrap": "prefer_line",
    "tab_size": 4,
    "agent_servers": {
        "opencode": {
            "type": "registry"
        },
        "github-copilot-cli": {
            "type": "registry",
        },
        "github-copilot": {
            "type": "registry",
        },
    },
    "chat_panel": {
        "dock": "left",
    },
    "project_panel": {
        "dock": "right",
        "auto_fold_dirs": false,
        "git_status": true,
    },
    "outline_panel": {
        "dock": "left",
    },
    "notification_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "agent": {
        "favorite_models": [
            {
                "provider": "zed.dev",
                "model": "gpt-5.5",
                "enable_thinking": true,
                "effort": "xhigh",
            },
        ],
        "dock": "left",
        "default_profile": "write",
        "default_model": {
            "effort": "xhigh",
            "enable_thinking": true,
            "provider": "zed.dev",
            "model": "gpt-5.5",
        },
        "model_parameters": [],
    },
    "edit_predictions": {
        "provider": "zed",
        "mode": "subtle",
    },
    "buffer_font_family": "JetBrainsMono Nerd Font Mono",
    "ui_font_family": "SF Pro Text",
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "vim_mode": true,
    "base_keymap": "VSCode",
    "ui_font_size": 14,
    "buffer_font_size": 15.5,
    "theme": {
        "mode": "light",
        "light": "Ayu Light",
        "dark": "Ayu Dark",
    },
    "auto_install_extensions": {
        "git-firefly": true,
        "ruff": true,
        "toml": true,
        "golangci-lint": true,
        "gosum": true,
        "php": true,
        "vue": true,
        "dockerfile": true,
        "docker-compose": true,
        "catppuccin": true,
        "catppuccin-icons": true,
        "java": true,
        "sql": true,
        "make": true,
        "xml": true,
    },
    "languages": {
        "Python": {
            "linked_edits": true,
            "show_edit_predictions": true,
            "wrap_guides": [120],
            "preferred_line_length": 120,
            "soft_wrap": "prefer_line",
            "tab_size": 4,
        },
    },
    "terminal": {
        "font_family": "JetBrainsMono Nerd Font",
        "font_size": 14.0,
        "env": {
            "FIG_NEW_SESSION": "\"1\"",
        },
        "detect_venv": {
            "on": {
                "directories": [".env", "env", "venv", ".venv"],
                "activate_script": "default",
            },
        },
    },
    "file_finder": {
        "modal_max_width": "medium",
    },
    "which_key": {
        "enabled": true,
        "delay_ms": 500,
    },
    "tab_bar": {
        "show": true,
    },
    "indent_guides": {
        "enabled": true,
        "coloring": "indent_aware",
    },
}
